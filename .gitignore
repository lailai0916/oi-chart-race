# ─── Python ──────────────────────────────────────────────────────────────────
.venv/
__pycache__/
*.pyc
*.pyo
*.egg-info/
.python-version.local

# ─── Node / Remotion ─────────────────────────────────────────────────────────
remotion/node_modules/
remotion/.remotion-cache/
remotion/dist/

# ─── Build outputs (large binary artifacts) ──────────────────────────────────
# We deliberately do NOT commit videos/parquets to the repo. They're
# regenerated by `make video` and optionally published as GitHub Release
# assets.
output/*.mp4
output/*.parquet
output/*.png
output/*.jpg
output/*.gif

remotion/public/snapshots.json

# ─── Copyrighted music bed (supply your own; never commit) ───────────────────
# tools/compose.sh expects a track here for `make final`.
/time.mp4
/*.mp3
/*.wav
/*.m4a

# ─── OS / Editor ─────────────────────────────────────────────────────────────
.DS_Store
.idea/
.vscode/
*.swp

# ─── Local-only files ────────────────────────────────────────────────────────
.env
.env.local
